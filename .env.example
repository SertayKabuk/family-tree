# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/familytree"

# Auth.js - Generate secret with: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-here"

# Google OAuth - Get from https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# Required for self-hosted deployments
AUTH_TRUST_HOST=true

# Auth.js canonical URL - used for OAuth redirect URIs
AUTH_URL="http://localhost:3000"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Local file storage directory
UPLOAD_DIR="./uploads"

# Azure OpenAI configuration
AZURE_OPENAI_ENDPOINT="https://your-azure-openai-endpoint.openai.azure.com/"
AZURE_OPENAI_API_KEY="your-azure-openai-key"
AZURE_OPENAI_DEPLOYMENT="your-azure-openai-deployment-name"

# Google API Key - Get from https://console.cloud.google.com/apis/credentials
GOOGLE_API_KEY="your-google-api-key"
GOOGLE_LLM_MODEL="gemma-4-31b-it"

# DeepAgent configuration
DEEPAGENT_LLM_MODEL="gemini-3-flash-preview"